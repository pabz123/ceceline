<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <template id="cellar_one_homepage" inherit_id="website.homepage" name="Cellar One Homepage">
      <xpath expr="//div[@id='wrap']" position="inside">
        
        <!-- Luxury Editorial Hero Section -->
        <section class="co-luxury-hero position-relative overflow-hidden d-flex align-items-center" style="background-color: var(--co-cream); min-height: 85vh; border-bottom: 1px solid rgba(197, 168, 128, 0.22);">
            <!-- Gold border frame -->
            <div class="co-hero-gold-border"></div>
            <!-- Left/Right decorative gradients -->
            <div class="co-hero-decoration co-hero-decoration--left"></div>
            <div class="co-hero-decoration co-hero-decoration--right"></div>
            <!-- Corner flourishes -->
            <div class="co-corner-flourish co-corner-flourish--tl"></div>
            <div class="co-corner-flourish co-corner-flourish--tr"></div>
            <div class="co-corner-flourish co-corner-flourish--bl"></div>
            <div class="co-corner-flourish co-corner-flourish--br"></div>
            <!-- Decorative Background Glow -->
            <div class="co-hero-ambient-glow"></div>
            
            <div class="container position-relative" style="z-index: 2; padding: 80px 0;">
                <div class="row align-items-center g-5">
                    <div class="col-lg-6 text-start">
                        <!-- Luxury Label -->
                        <span class="text-uppercase fw-bold mb-3 d-inline-flex align-items-center gap-2" style="color: var(--co-gold-dark); letter-spacing: 5px; font-size: 0.8rem;">
                            <span style="width: 12px; height: 1px; background-color: var(--co-gold-dark);"></span>
                            Est. 2018 · Cellar One
                        </span>
                        
                        <!-- High Contrast Title -->
                        <h1 class="display-3 fw-bold mb-4" style="font-family: var(--co-font-heading); line-height: 1.1; letter-spacing: -0.01em; color: #111111 !important;">
                            Curated Vintages<br/>
                            <span style="font-style: italic; font-weight: 400; color: var(--co-gold-dark);">For Connoisseurs</span>
                        </h1>
                        
                        <div class="co-hero-divider my-4" style="width: 60px; height: 1.5px; background-color: var(--co-gold-dark);"></div>
                        
                        <!-- High Contrast Description -->
                        <p class="lead mb-5" style="font-family: var(--co-font-body); font-weight: 300; color: var(--co-text-secondary) !important; font-size: 1.15rem; max-width: 520px; line-height: 1.8;">
                            Discover exceptional vintages and rare spirits handpicked by our expert sommeliers. Imported directly from the world's most historical vineyards.
                        </p>
                        
                        <!-- Premium Action CTAs -->
                        <div class="d-flex flex-wrap gap-3">
                            <a href="/shop" class="btn btn-lg rounded-pill px-5 py-3 co-hero-cta-primary" style="background-color: var(--co-gold); border-color: var(--co-gold); color: #111111; font-weight: 700; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 2px; transition: all 0.3s ease;">
                                Explore Catalog
                            </a>
                            <a href="/location" class="btn btn-lg btn-outline-dark rounded-pill px-5 py-3 text-uppercase fw-bold" style="font-size: 0.9rem; letter-spacing: 2px; border-width: 1.5px; color: #111111; border-color: rgba(17,17,17,0.4); transition: all 0.3s ease;">
                                Visit Boutique
                            </a>
                        </div>
                    </div>
                    
                    <div class="col-lg-6 d-none d-lg-block">
                        <div class="co-hero-spotlight position-relative mx-auto" style="width: 400px; height: 480px;">
                            <div class="co-spotlight-frame"></div>
                            
                            <!-- Main Showcase -->
                            <div class="co-spotlight-img-wrap overflow-hidden" style="width: 100%; height: 100%; border-radius: 4px; box-shadow: 0 20px 45px rgba(0,0,0,0.08); background-color: #FAF8F5;">
                                <img src="/website_cellar_one/static/src/img/hero_banner.png" alt="Cellar One Bottle Showcase" style="width: 100%; height: 100%; object-fit: cover; opacity: 0.95; transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Perks / Trust Bar -->
        <section class="co-trust-bar py-4 bg-white border-bottom">
            <div class="container">
                <div class="row text-center g-4">
                    <div class="col-md-3 col-6">
                        <div class="co-perk-item d-flex align-items-center justify-content-center gap-3">
                            <span class="co-perk-icon fs-4" style="color: var(--co-gold);">🍷</span>
                            <div class="text-start">
                                <h6 class="fw-bold mb-0" style="font-size: 0.9rem; color: #111111;">Sommelier Selection</h6>
                                <p class="text-muted small mb-0 text-truncate">Expertly hand-curated bottles</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="co-perk-item d-flex align-items-center justify-content-center gap-3">
                            <span class="co-perk-icon fs-4" style="color: var(--co-gold);">🚚</span>
                            <div class="text-start">
                                <h6 class="fw-bold mb-0" style="font-size: 0.9rem; color: #111111;">Express Delivery</h6>
                                <p class="text-muted small mb-0 text-truncate">Kampala &amp; Jinja regions</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="co-perk-item d-flex align-items-center justify-content-center gap-3">
                            <span class="co-perk-icon fs-4" style="color: var(--co-gold);">💬</span>
                            <div class="text-start">
                                <h6 class="fw-bold mb-0" style="font-size: 0.9rem; color: #111111;">WhatsApp Concierge</h6>
                                <p class="text-muted small mb-0 text-truncate">Direct ordering support</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-6">
                        <div class="co-perk-item d-flex align-items-center justify-content-center gap-3">
                            <span class="co-perk-icon fs-4" style="color: var(--co-gold);">🔒</span>
                            <div class="text-start">
                                <h6 class="fw-bold mb-0" style="font-size: 0.9rem; color: #111111;">100% Authenticity</h6>
                                <p class="text-muted small mb-0 text-truncate">Direct authenticated imports</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Circular Categories Navigation -->
        <section class="co-category-strip py-5" style="background-color: var(--co-cream);">
            <div class="container text-center py-3">
                <div class="text-center mb-5">
                    <span class="co-section-label">Classifications</span>
                    <h2 class="mt-2 co-section-title">Shop By Category</h2>
                    <div class="co-divider mx-auto mt-2 mb-3"></div>
                    <p class="text-muted">Explore our curated collections by beverage classification</p>
                </div>
                <div class="d-flex flex-wrap justify-content-center gap-5 mt-4">
                    <a href="/shop/category/wines-27">
                        <div class="co-category-circle-link text-decoration-none d-block">
                        <div class="co-category-circle" style="background-color: #ffffff; border: 1px solid rgba(197, 168, 128, 0.3); width: 100px; height: 100px; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 15px rgba(0,0,0,0.03); transition: all 0.4s ease; overflow: hidden;">
                            <img src="/website_cellar_one/static/src/img/cat_wines.png" style="width: 100%; height: 100%; object-fit: cover;" alt="Wines"/>
                        </div>
                        <h6 class="mt-3 fw-bold text-uppercase text-dark small" style="letter-spacing: 2px; font-size: 0.75rem;">Wines</h6>
                        </div>
                    </a>
                    <a href="/shop/category/spirits-28">
                        <div class="co-category-circle-link text-decoration-none d-block">
                        <div class="co-category-circle" style="background-color: #ffffff; border: 1px solid rgba(197, 168, 128, 0.3); width: 100px; height: 100px; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 15px rgba(0,0,0,0.03); transition: all 0.4s ease; overflow: hidden;">
                            <img src="/website_cellar_one/static/src/img/cat_spirits.png" style="width: 100%; height: 100%; object-fit: cover;" alt="Spirits"/>
                        </div>
                        <h6 class="mt-3 fw-bold text-uppercase text-dark small" style="letter-spacing: 2px; font-size: 0.75rem;">Spirits</h6>
                        </div>
                    </a>
                    <a href="/shop/category/beer-34">
                        <div class="co-category-circle-link text-decoration-none d-block">
                        <div class="co-category-circle" style="background-color: #ffffff; border: 1px solid rgba(197, 168, 128, 0.3); width: 100px; height: 100px; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 15px rgba(0,0,0,0.03); transition: all 0.4s ease; overflow: hidden;">
                            <img src="/website_cellar_one/static/src/img/cat_beer.png" style="width: 100%; height: 100%; object-fit: cover;" alt="Beer"/>
                        </div>
                        <h6 class="mt-3 fw-bold text-uppercase text-dark small" style="letter-spacing: 2px; font-size: 0.75rem;">Beer</h6>
                        </div>
                    </a>
                    <a href="/shop/category/cider-35">
                        <div class="co-category-circle-link text-decoration-none d-block">
                        <div class="co-category-circle" style="background-color: #ffffff; border: 1px solid rgba(197, 168, 128, 0.3); width: 100px; height: 100px; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 15px rgba(0,0,0,0.03); transition: all 0.4s ease; overflow: hidden;">
                            <img src="/website_cellar_one/static/src/img/cat_cider.png" style="width: 100%; height: 100%; object-fit: cover;" alt="Cider"/>
                        </div>
                        <h6 class="mt-3 fw-bold text-uppercase text-dark small" style="letter-spacing: 2px; font-size: 0.75rem;">Cider</h6>
                        </div>
                    </a>
                </div>
                </div>
        </section>

        <!-- Dynamic Curated Vintages / Live Products Grid -->
        <section class="co-live-vintages py-5 bg-white border-top border-bottom">
            <div class="container py-4">
                <div class="text-center mb-5">
                    <span class="co-section-label">Sommelier Selections</span>
                    <h2 class="mt-2 co-section-title">Featured Vintages</h2>
                    <div class="co-divider mx-auto mt-2 mb-3"></div>
                    <p class="text-muted">Directly loaded from our boutique reserves</p>
                </div>

                <!-- Fetch dynamic products from Odoo database -->
                <t t-set="live_products" t-value="request.env['product.template'].sudo().search([('website_published', '=', True)], limit=4)"/>

                <t t-if="live_products">
                    <div class="row g-0 co-home-grid">
                        <t t-foreach="live_products" t-as="prod">
                            <div class="col-lg-3 col-md-6 co-home-prod-cell">
                                <a t-att-href="prod.website_url" class="text-decoration-none">
                                    <div class="co-home-prod-img-wrap">
                                        <img t-att-src="website.image_url(prod, 'image_512')" class="co-home-prod-img" t-att-alt="prod.name"/>
                                        <div class="co-stock-badge-container position-absolute top-0 start-0 p-2" t-att-data-product-id="prod.product_variant_id.id if prod.product_variant_id else prod.id">
                                        </div>
                                    </div>
                                    <span class="co-home-prod-category" t-esc="prod.public_categ_ids[0].name if prod.public_categ_ids else 'Exclusive'"/>
                                    <h5 class="co-home-prod-title" t-esc="prod.name"/>

                                    <div class="co-home-prod-rating">
                                        <t t-if="prod.rating_count">
                                            <t t-foreach="range(1, 6)" t-as="i">
                                                <span t-attf-class="co-home-star #{'filled' if i &lt;= prod.rating_avg else ''}">★</span>
                                            </t>
                                            <span class="co-home-rating-count">(<t t-esc="prod.rating_count"/>)</span>
                                        </t>
                                        <t t-else="">
                                            <span class="text-muted small italic">No reviews yet</span>
                                        </t>
                                    </div>
                                    <t t-set="combination_info" t-value="prod._get_combination_info(only_template=True)"/>
                                    <div class="co-home-prod-price">
                                        <t t-if="combination_info['has_discounted_price']">
                                            <span class="co-price-sale">
                                                <span t-esc="combination_info['price']" t-options="{'widget': 'monetary', 'display_currency': website.currency_id}"/>
                                            </span>
                                            <span class="co-price-original">
                                                <span t-esc="combination_info['list_price']" t-options="{'widget': 'monetary', 'display_currency': website.currency_id}"/>
                                            </span>
                                        </t>
                                        <t t-else="">
                                            <span class="co-price-regular">
                                                <span t-esc="combination_info['price']" t-options="{'widget': 'monetary', 'display_currency': website.currency_id}"/>
                                            </span>
                                        </t>
                                    </div>
                                </a>
                            </div>
                        </t>
                    </div>
                </t>
                <t t-else="">
                    <!-- Fallback placeholders if DB is empty -->
                    <div class="row g-0 co-home-grid">
                        <div class="col-lg-3 col-md-6 co-home-prod-cell">
                            <div class="co-home-prod-img-wrap co-home-fallback-img">
                                <img src="/website_cellar_one/static/src/img/featured_champagne.png" class="co-home-prod-img" alt="Saint Celine"/>
                            </div>
                            <span class="co-home-prod-category">Wine</span>
                            <h5 class="co-home-prod-title">Saint Celine Natural Sweet Red</h5>
                            <div class="co-home-prod-rating"><span class="co-home-star filled">★</span><span class="co-home-star filled">★</span><span class="co-home-star filled">★</span><span class="co-home-star filled">★</span><span class="co-home-star filled">★</span> <span class="co-home-rating-count">(5)</span></div>
                            <div class="co-home-prod-price"><span class="co-price-sale">UGX 32,300</span><span class="co-price-original">UGX 38,000</span></div>
                        </div>
                        <div class="col-lg-3 col-md-6 co-home-prod-cell">
                            <div class="co-home-prod-img-wrap co-home-fallback-img">
                                <img src="/website_cellar_one/static/src/img/hero_banner.png" class="co-home-prod-img" alt="Cabernet"/>
                            </div>
                            <span class="co-home-prod-category">Wine</span>
                            <h5 class="co-home-prod-title">Premium Cabernet Sauvignon</h5>
                            <div class="co-home-prod-rating"><span class="co-home-star filled">★</span><span class="co-home-star filled">★</span><span class="co-home-star filled">★</span><span class="co-home-star filled">★</span><span class="co-home-star">★</span> <span class="co-home-rating-count">(6)</span></div>
                            <div class="co-home-prod-price"><span class="co-price-sale">UGX 93,500</span><span class="co-price-original">UGX 110,000</span></div>
                        </div>
                        <div class="col-lg-3 col-md-6 co-home-prod-cell">
                            <div class="co-home-prod-img-wrap co-home-fallback-img">
                                <img src="/website_cellar_one/static/src/img/featured_whisky.png" class="co-home-prod-img" alt="Whiskey"/>
                            </div>
                            <span class="co-home-prod-category">Spirits</span>
                            <h5 class="co-home-prod-title">Aged Single Malt Whiskey</h5>
                            <div class="co-home-prod-rating"><span class="co-home-star filled">★</span><span class="co-home-star filled">★</span><span class="co-home-star filled">★</span><span class="co-home-star filled">★</span><span class="co-home-star filled">★</span> <span class="co-home-rating-count">(5)</span></div>
                            <div class="co-home-prod-price"><span class="co-price-sale">UGX 288,000</span><span class="co-price-original">UGX 320,000</span></div>
                        </div>
                        <div class="col-lg-3 col-md-6 co-home-prod-cell">
                            <div class="co-home-prod-img-wrap co-home-fallback-img">
                                <span class="fs-1">🍺</span>
                            </div>
                            <span class="co-home-prod-category">Beer</span>
                            <h5 class="co-home-prod-title">Tusker Lager 500ml Can (6-Pack)</h5>
                            <div class="co-home-prod-rating"><span class="co-home-star filled">★</span><span class="co-home-star filled">★</span><span class="co-home-star filled">★</span><span class="co-home-star filled">★</span><span class="co-home-star">★</span> <span class="co-home-rating-count">(10)</span></div>
                            <div class="co-home-prod-price"><span class="co-price-sale">UGX 36,100</span><span class="co-price-original">UGX 38,000</span></div>
                        </div>
                    </div>
                </t>
            </div>
        </section>

        <!-- Flagship Bottle Showcase -->
        <section class="co-bottle-showcase py-5" style="background-color: var(--co-cream);">
            <div class="container py-5">
                <div class="text-center mb-5">
                    <span class="co-section-label">Boutique Highlight</span>
                    <h2 class="mt-2 co-section-title">Our Flagship Selection</h2>
                    <div class="co-divider mx-auto mt-2 mb-3"></div>
                    <p class="text-muted">A closer look at this month's featured sommelier choice</p>
                </div>
                
                <div class="row align-items-center mt-5">
                    <!-- Left side: callouts -->
                    <div class="col-md-4 text-md-end text-center">
                        <div class="co-showcase-callout mb-5 p-3" style="border-right: 1px solid rgba(197,168,128,0.3); transition: all 0.3s ease;">
                            <h5 class="fw-bold" style="color: var(--co-charcoal);">Nose (Aroma)</h5>
                            <p class="text-muted small">Rich and complex bouquet displaying dark cherry, ripe plums, vanilla, and fine oak undertones.</p>
                        </div>
                        <div class="co-showcase-callout mb-0 p-3" style="border-right: 1px solid rgba(197,168,128,0.3); transition: all 0.3s ease;">
                            <h5 class="fw-bold" style="color: var(--co-charcoal);">Palate (Taste)</h5>
                            <p class="text-muted small">Full-bodied, smooth tannins with a lingering finish. Notes of dark chocolate, berry fruits, and subtle spice.</p>
                        </div>
                    </div>
                    
                    <!-- Center: Large Bottle Image -->
                    <div class="col-md-4 text-center my-4 my-md-0">
                        <t t-set="flagship_prod" t-value="request.env['product.template'].sudo().search([('name', '=ilike', 'Premium Cabernet Sauvignon')], limit=1)"/>
                        <div class="co-showcase-bottle-wrapper position-relative d-inline-block">
                            <div class="co-bottle-glow" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 180px; height: 180px; background: radial-gradient(circle, rgba(197, 168, 128, 0.22) 0%, transparent 70%); z-index: -1;"></div>
                            <img t-att-src="website.image_url(flagship_prod, 'image_512') if flagship_prod else '/website_cellar_one/static/src/img/hero_banner.png'" alt="Flagship Bottle" class="img-fluid" style="max-height: 400px; filter: drop-shadow(0 20px 45px rgba(0,0,0,0.12)); transition: all 0.5s ease;"/>
                        </div>
                        <div class="mt-4">
                            <h4 class="fw-bold mb-1" style="font-family: var(--co-font-heading); color: #111111; letter-spacing: 1px;">Cabernet Sauvignon</h4>
                            <span class="badge px-3 py-2 rounded-pill fw-bold" style="background-color: var(--co-gold-dark); color: #ffffff; font-size: 0.7rem; letter-spacing: 1px; text-transform: uppercase;">Special Reserva</span>
                        </div>
                    </div>
                    
                    <!-- Right side: callouts -->
                    <div class="col-md-4 text-md-start text-center">
                        <div class="co-showcase-callout mb-5 p-3" style="border-left: 1px solid rgba(197,168,128,0.3); transition: all 0.3s ease;">
                            <h5 class="fw-bold" style="color: var(--co-charcoal);">Perfect Pairing</h5>
                            <p class="text-muted small">Accompanies beautifully with prime cuts of grilled ribeye steak, roasted lamb, or slow-cooked game dishes.</p>
                        </div>
                        <div class="co-showcase-callout mb-0 p-3" style="border-left: 1px solid rgba(197,168,128,0.3); transition: all 0.3s ease;">
                            <h5 class="fw-bold" style="color: var(--co-charcoal);">Optimal Service</h5>
                            <p class="text-muted small">Serve at a cellar temperature of 16-18°C. We recommend decanting for at least 30 minutes before serving.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Curated Collections Section -->
        <section class="co-featured-collections py-5 bg-white">
            <div class="container py-4">
                <div class="text-center mb-5">
                    <span class="co-section-label">Premium Collections</span>
                    <h2 class="mt-2 co-section-title">Curated For Connoisseurs</h2>
                    <div class="co-divider mx-auto mt-2 mb-3"></div>
                    <p class="text-muted mx-auto" style="max-width: 600px;">Explore our hand-selected categories featuring the world's most sought-after luxury beverages.</p>
                </div>
                
                <div class="row g-4">
                    <!-- Featured Whisky -->
                    <div class="col-md-6">
                        <div class="card border-0 overflow-hidden co-pinterest-card" style="border-radius: 4px; box-shadow: 0 15px 40px rgba(0,0,0,0.06); border: 1px solid rgba(197,168,128,0.18);">
                            <div class="position-relative" style="height: 420px;">
                                <img src="/website_cellar_one/static/src/img/featured_whisky.png" class="w-100 h-100 co-zoom-img" style="object-fit: cover; transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);" alt="Premium Whisky"/>
                                <div class="position-absolute w-100 h-100 top-0 start-0" style="background: linear-gradient(to top, rgba(12, 12, 14, 0.9) 0%, rgba(12, 12, 14, 0.2) 60%, transparent 100%);"></div>
                                <div class="position-absolute bottom-0 start-0 p-4 w-100 text-start">
                                    <span class="text-uppercase fw-bold small d-inline-block mb-1" style="color: var(--co-gold); letter-spacing: 2px;">Premium Scotch</span>
                                    <h3 class="text-white mb-2 fw-bold" style="font-family: var(--co-font-heading); color: #FAF8F5 !important;">Single Malt Whisky</h3>
                                    <p class="mb-4 small" style="max-width: 340px; color: rgba(250, 248, 245, 0.85);">Rich, complex, peat-smoked and aged in oak barrels to absolute perfection.</p>
                                    <a href="/shop/category/spirits-28" class="btn btn-outline-light rounded-pill px-4 text-uppercase fw-bold btn-sm" style="letter-spacing: 2px; border-width: 1.5px; font-size: 0.75rem; color: #FAF8F5; border-color: rgba(250,248,245,0.4);">Shop Whisky</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Featured Champagne -->
                    <div class="col-md-6">
                        <div class="card border-0 overflow-hidden co-pinterest-card" style="border-radius: 4px; box-shadow: 0 15px 40px rgba(0,0,0,0.06); border: 1px solid rgba(197,168,128,0.18);">
                            <div class="position-relative" style="height: 420px;">
                                <img src="/website_cellar_one/static/src/img/featured_champagne.png" class="w-100 h-100 co-zoom-img" style="object-fit: cover; transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);" alt="Luxury Champagne"/>
