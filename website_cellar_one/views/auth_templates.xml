<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- LOGIN PAGE -->
  <template id="custom_login" inherit_id="web.login" name="Cellar One Login">
    <xpath expr="//form[hasclass('oe_login_form')]" position="replace">
      <div class="co-auth-container" style="max-width: 400px; margin: 0 auto; padding: 2rem 0;">
        <div class="text-center mb-4">
          <img src="/website_cellar_one/static/src/img/logo/ce_logo.png" alt="Cellar One Logo" style="height: 60px; object-fit: contain; margin-bottom: 1rem;"/>
          <h2 style="font-family: var(--co-font-heading); color: var(--co-burgundy);">Welcome Back</h2>
          <p class="text-muted">Sign in to your account</p>
        </div>
        
        <form class="oe_login_form space-y-6" role="form" t-attf-action="/web/login" method="post" onsubmit="this.querySelector('button[type=submit]').disabled = true;">
          <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
          <input type="hidden" name="redirect" t-att-value="redirect"/>

          <div class="mb-3">
            <label for="login" class="form-label fw-bold text-muted" style="font-size: 0.85rem;">Email</label>
            <input type="text" name="login" t-att-value="login" id="login" class="form-control" required="required" autofocus="autofocus" autocapitalize="off" placeholder="your.email@example.com" style="height: 48px; border-radius: 8px;"/>
          </div>

          <div class="mb-4 position-relative">
            <div class="d-flex justify-content-between">
              <label for="password" class="form-label fw-bold text-muted" style="font-size: 0.85rem;">Password</label>
              <a t-if="reset_password_enabled" t-attf-href="/web/reset_password?{{ keep_query() }}" class="text-decoration-none" style="font-size: 0.85rem; color: var(--co-burgundy); font-weight: 500;">Forgot Password?</a>
            </div>
            <input type="password" name="password" id="password" class="form-control" required="required" autocomplete="current-password" placeholder="Enter your password" t-att-autofocus="'autofocus' if login else None" maxlength="4096" style="height: 48px; border-radius: 8px;"/>
          </div>

          <!-- Required by auth_oauth module -->
          <div class="o_login_auth"/>

          <p class="alert alert-danger" t-if="error" role="alert">
              <t t-esc="error"/>
          </p>
          <p class="alert alert-success" t-if="message" role="status">
              <t t-esc="message"/>
          </p>

          <button type="submit" class="btn btn-primary w-100" style="height: 48px; border-radius: 8px; background-color: var(--co-burgundy); border-color: var(--co-burgundy); font-weight: 600;">Sign In</button>
          
          <div class="text-center mt-4 pt-3 border-top">
            <p class="text-muted mb-0" style="font-size: 0.9rem;">
              Don't have an account? 
              <a t-if="signup_enabled" t-attf-href="/web/signup?{{ keep_query() }}" class="text-decoration-none fw-bold" style="color: var(--co-burgundy);">Register Now</a>
            </p>
          </div>
        </form>
      </div>
    </xpath>
  </template>

  <!-- SIGNUP PAGE -->
  <template id="custom_signup" inherit_id="auth_signup.signup" name="Cellar One Signup">
    <xpath expr="//form[hasclass('oe_signup_form')]" position="replace">
      <div class="co-auth-container" style="max-width: 400px; margin: 0 auto; padding: 2rem 0;">
        <div class="text-center mb-4">
          <img src="/website_cellar_one/static/src/img/logo/ce_logo.png" alt="Cellar One Logo" style="height: 60px; object-fit: contain; margin-bottom: 1rem;"/>
          <h2 style="font-family: var(--co-font-heading); color: var(--co-burgundy);">Create Account</h2>
          <p class="text-muted">Join Uganda's premium wines &amp; spirits destination.</p>
        </div>
        
        <form class="oe_signup_form" role="form" method="post" t-if="not message" onsubmit="return validateSignup(this);">
          <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
          <input type="hidden" name="token" t-att-value="token"/>
          <input type="hidden" name="redirect" t-att-value="redirect"/>

          <div class="mb-3">
            <label for="name" class="form-label fw-bold text-muted" style="font-size: 0.85rem;">Full Name</label>
            <input type="text" name="name" id="name" class="form-control" required="required" t-att-value="name" t-att-readonly="'readonly' if only_passwords else None" t-att-autofocus="'autofocus' if login and not only_passwords else None" placeholder="your name" style="height: 48px; border-radius: 8px;"/>
          </div>

          <div class="mb-3">
            <label for="login" class="form-label fw-bold text-muted" style="font-size: 0.85rem;">Email Address</label>
            <input type="email" name="login" id="login" class="form-control" required="required" t-att-value="login" t-att-readonly="'readonly' if only_passwords else None" placeholder="your.email@example.com" style="height: 48px; border-radius: 8px;"/>
            <div id="email-error" class="text-danger mt-1 d-none" style="font-size: 0.8rem;">Please enter a valid email address.</div>
          </div>

          <div class="mb-3">
            <label for="password" class="form-label fw-bold text-muted" style="font-size: 0.85rem;">Password</label>
            <input type="password" name="password" id="password" class="form-control" required="required" t-att-autofocus="'autofocus' if only_passwords else None" placeholder="Min. 8 characters" minlength="8" style="height: 48px; border-radius: 8px;"/>
          </div>

          <div class="mb-4">
            <label for="confirm_password" class="form-label fw-bold text-muted" style="font-size: 0.85rem;">Confirm Password</label>
            <input type="password" name="confirm_password" id="confirm_password" class="form-control" required="required" placeholder="Repeat your password" style="height: 48px; border-radius: 8px;"/>
            <div id="password-error" class="text-danger mt-1 d-none" style="font-size: 0.8rem;">Passwords do not match.</div>
          </div>

          <!-- Required by auth_oauth module -->
          <div class="o_login_auth"/>

          <p class="alert alert-danger" t-if="error" role="alert">
              <t t-esc="error"/>
          </p>
          <input type="hidden" name="redirect" t-att-value="redirect"/>
          
          <button type="submit" class="btn btn-primary w-100" style="height: 48px; border-radius: 8px; background-color: var(--co-burgundy); border-color: var(--co-burgundy); font-weight: 600;">Sign Up</button>
          
          <div class="text-center mt-4 pt-3 border-top">
            <p class="text-muted mb-0" style="font-size: 0.9rem;">
              Already have an account? 
              <a t-attf-href="/web/login?{{ keep_query() }}" class="text-decoration-none fw-bold" style="color: var(--co-burgundy);">Sign In</a>
            </p>
          </div>
        </form>

        <!-- JS Validation Script -->
        <script type="text/javascript">
          function validateSignup(form) {
            const email = form.querySelector('#login').value;
            const pwd = form.querySelector('#password').value;
            const confirm = form.querySelector('#confirm_password').value;
            
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            // Password requires: min 8 chars, 1 uppercase, 1 lowercase, 1 number or special char
            const pwdRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*[\d\W]).{8,}$/;
            let isValid = true;
            
            if (!emailRegex.test(email)) {
              document.getElementById('email-error').classList.remove('d-none');
              isValid = false;
            } else {
              document.getElementById('email-error').classList.add('d-none');
            }
            
            let pwdError = document.getElementById('password-error');
            if (!pwdRegex.test(pwd)) {
              pwdError.innerText = 'Password must be at least 8 characters, include an uppercase letter, and a number/special character.';
              pwdError.classList.remove('d-none');
              isValid = false;
            } else if (pwd !== confirm) {
              pwdError.innerText = 'Passwords do not match.';
              pwdError.classList.remove('d-none');
              isValid = false;
            } else {
              pwdError.classList.add('d-none');
            }
            
            if(isValid) {
              form.querySelector('button[type=submit]').disabled = true;
              return true;
            }
            return false;
          }
        </script>
      </div>
    </xpath>
  </template>
</odoo>
